shapes.py
def circle_area(r):
    return 3.14 * r * r

def rectangle_area(l, w):
    return l * w

def triangle_area(b, h):
    return 0.5 * b * h
main.py
import shapes

print("Circle Area:", shapes.circle_area(5))
print("Rectangle Area:", shapes.rectangle_area(4, 6))
print("Triangle Area:", shapes.triangle_area(3, 8))
